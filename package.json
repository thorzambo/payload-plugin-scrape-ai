{
  "name": "payload-plugin-scrape-ai",
  "version": "0.1.0",
  "description": "Payload CMS plugin that auto-generates AI-friendly content (llms.txt, markdown, JSON-LD)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/admin/views/Dashboard.js",
      "types": "./dist/admin/views/Dashboard.d.ts"
    },
    "./NavLink": {
      "import": "./dist/admin/components/NavLink.js",
      "types": "./dist/admin/components/NavLink.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true }
  },
  "devDependencies": {
    "payload": "^3.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "license": "MIT"
}
